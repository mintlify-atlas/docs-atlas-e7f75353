  "keyFeatures": [
    "Local-first semantic search with browser-based embeddings",
    "Privacy-focused RAG with GitHub stars",
    "Multi-provider LLM support (WebLLM, Ollama, Remote)",
    "OAuth and PAT authentication",
    "Persistent chat sessions with SQLite",
    "WebGPU-accelerated embeddings with WASM fallback",
    "Adaptive batching for large star collections",
    "Checkpointed indexing with resume support"
